// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum HikingLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TripDifficulty {
  EASY
  MODERATE
  HARD
  EXPERT
}

model User {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  email         String      @unique
  name          String?
  password      String
  age           Int
  cnic          String?
  hikingLevel   HikingLevel @default(BEGINNER)
  emailVerified Boolean     @default(false)
  trips         Trip[]
  joinRequests  JoinReq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JoinReq {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  hikeId String @db.ObjectId

  status JoinStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  trip Trip @relation(fields: [hikeId], references: [id])

  @@unique([userId, hikeId]) // prevents duplicate requests
}

model Trip {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String
  location    String

  startDate DateTime
  endDate   DateTime

  difficulty          TripDifficulty @default(EASY)
  maxParticipants     Int
  currentParticipants Int            @default(1)

  images String[] // Array of Cloudinary URLs

  isPublic Boolean @default(true)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  participants String[]  @db.ObjectId
  joinRequests JoinReq[]
}
